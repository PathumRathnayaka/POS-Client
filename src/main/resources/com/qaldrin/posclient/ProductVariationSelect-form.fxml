<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane
        prefHeight="310.0"
        prefWidth="440.0"
        style="-fx-background-color: #1f2a35; -fx-border-color: #4a90e2; -fx-border-width: 2px; -fx-border-radius: 6px; -fx-background-radius: 6px;"
        xmlns="http://javafx.com/javafx/20.0.1"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.qaldrin.posclient.controller.ProductVariationSelectController">

    <children>
        <VBox
                alignment="TOP_CENTER"
                spacing="16.0"
                AnchorPane.topAnchor="24.0"
                AnchorPane.bottomAnchor="24.0"
                AnchorPane.leftAnchor="24.0"
                AnchorPane.rightAnchor="24.0">

            <children>

                <!-- Title -->
                <Label
                        text="SELECT VARIATION"
                        style="-fx-text-fill: #4a90e2; -fx-font-weight: bold;" >
                    <font><Font size="17.0" /></font>
                </Label>

                <!-- Divider -->
                <Separator style="-fx-opacity: 0.25;" />

                <!-- Product Name -->
                <VBox spacing="3.0">
                    <children>
                        <Label
                                text="Product Name:"
                                style="-fx-text-fill: #8fa3b1; -fx-font-size: 12px;" />
                        <Label
                                fx:id="productNameLabel"
                                text="Product"
                                style="-fx-text-fill: white; -fx-font-weight: bold;">
                            <font><Font size="16.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <!-- Variation ComboBox -->
                <VBox spacing="6.0">
                    <children>
                        <Label
                                text="Choose Variation:"
                                style="-fx-text-fill: #8fa3b1; -fx-font-size: 12px;" />
                        <ComboBox
                                fx:id="variationComboBox"
                                prefHeight="40.0"
                                prefWidth="392.0"
                                promptText="Select a variation..."
                                style="-fx-background-color: #2c3e50;
                                   -fx-border-color: #3d5166;
                                   -fx-border-width: 1px;
                                   -fx-border-radius: 4px;
                                   -fx-background-radius: 4px;
                                   -fx-text-fill: white;" />
                    </children>
                </VBox>

                <!-- Spacer -->
                <Region VBox.vgrow="ALWAYS" />

                <!-- Buttons -->
                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button
                                fx:id="btnCancel"
                                onAction="#onCancelClick"
                                prefHeight="40.0"
                                prefWidth="100.0"
                                text="CANCEL"
                                style="-fx-background-color: #c0392b;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 13px;
                                   -fx-background-radius: 5px;
                                   -fx-cursor: hand;" />
                        <Button
                                fx:id="btnSubmit"
                                onAction="#onSubmitClick"
                                prefHeight="40.0"
                                prefWidth="120.0"
                                text="SUBMIT"
                                style="-fx-background-color: #27ae60;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-font-size: 13px;
                                   -fx-background-radius: 5px;
                                   -fx-cursor: hand;" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
